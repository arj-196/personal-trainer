{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Web Server",
            "request": "launch",
            "cwd": "${workspaceFolder}/frontend",
            "type": "node",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "console": "internalConsole"
        },
        {
            "name": "Debug Next.js – Frontend (Chrome)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}", // the folder that contains the source files
            "sourceMaps": true, // use source maps for better breakpoint mapping
            "trace": true, // optional: prints debug logs to the Debug Console
            "runtimeExecutable": "stable", // change if you use another browser
            "port": 9222
        },
    ]
}